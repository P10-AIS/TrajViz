// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	"workspaceFolder": "/workspaces/TrajViz",
	"build": {
		// Path is relative to the devcontainer.json file.
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"bradlc.vscode-tailwindcss",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			]
		}
	},
	"postCreateCommand": "pip install -r server/requirements.txt && cd client && npm ci",
	"remoteUser": "root",
	"mounts": [
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Data,target=${containerWorkspaceFolder}/server/Data",
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Predictions,target=${containerWorkspaceFolder}/server/Predictions"
	],
	"shutdownAction": "none"
}