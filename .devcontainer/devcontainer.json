// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	"workspaceFolder": "/workspaces/TrajViz",
	"build": {
        // Path is relative to the devcontainer.json file.
        "dockerfile": "Dockerfile"
    },
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		}
	},
	"postCreateCommand": "cd client && npm ci && cd ../server && pip install -r requirements.txt",
	"customizations": {
		"vscode": {
			"extensions": [
				"bradlc.vscode-tailwindcss",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			]
		}
	},
	"mounts": [
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Data,target=${containerWorkspaceFolder}/Data",
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Outputs,target=${containerWorkspaceFolder}/Outputs",
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Results,target=${containerWorkspaceFolder}/Results",
		"type=bind,source=C:/Users/ANT/repos/studie/P10/Predictions,target=${containerWorkspaceFolder}/Predictions"
	],
	"shutdownAction": "none"
}